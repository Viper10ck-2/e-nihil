# ===========================================
# e-Nihil Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control!

# ===========================================
# CockroachDB Configuration (Database)
# ===========================================
# Daftar gratis di https://cockroachlabs.com
# Buat Serverless cluster → Connect → copy connection string
# Format: postgresql://user:password@host:26257/defaultdb?sslmode=verify-full

POSTGRES_URL=postgresql://user:password@host:26257/defaultdb?sslmode=verify-full
POSTGRES_PRISMA_URL=postgresql://user:password@host:26257/defaultdb?sslmode=verify-full&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:26257/defaultdb?sslmode=verify-full
POSTGRES_USER=your_user
POSTGRES_HOST=your-host.cockroachlabs.cloud
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=defaultdb

# ===========================================
# Email Configuration (Required for notifications)
# ===========================================
# Gmail SMTP settings for sending notification emails
# To get App Password:
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate a new app password for "Mail"

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# Admin email to receive new application notifications
ADMIN_EMAIL=admin@inspektorat.bintankab.go.id

# ===========================================
# Security Configuration
# ===========================================
# Secret key for one-time password migration (generate a random string)
# Use this to migrate existing plain text passwords to hashed passwords
# After migration, you can remove this or change it
MIGRATION_SECRET=your_random_migration_secret_here

# ===========================================
# Supabase Storage Configuration (File Storage)
# ===========================================
# Daftar gratis di https://supabase.com
# Buat project → Project Settings → API → copy URL & keys
# Bucket "documents" harus sudah dibuat dengan akses public

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: nama bucket (default: documents)
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=documents
# SUPABASE_STORAGE_BUCKET=documents

# ===========================================
# Application Settings (Optional)
# ===========================================
# Base URL for the application (auto-detected on Vercel)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
